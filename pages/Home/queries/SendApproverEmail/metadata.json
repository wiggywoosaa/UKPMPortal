{
  "gitSyncId": "69ccf8e72446822078bf9d91_d1656f6c-f082-4c7a-89f6-4cbe2a04bb69",
  "id": "Home_SendApproverEmail",
  "pluginId": "smtp-plugin",
  "pluginType": "DB",
  "unpublishedAction": {
    "actionConfiguration": {
      "body": "<html>\n<body style=\"font-family: Arial, sans-serif; font-size: 14px; color: #333;\">\n  <p>Hello,</p>\n  <p>All questions for your department have been answered and the Contract Review is ready for your sign off.</p>\n  <ul>\n    <li><strong>Contract Review:</strong> {{ appsmith.store.selectedPO }}</li>\n    <li><strong>Department:</strong> {{ appsmith.store.selectedDepartment }}</li>\n  </ul>\n  <p>Please log into the PM Portal to review and sign off your department's section.</p>\n  <br/>\n  <p>Thank you.</p>\n  <p><em>PM Portal (Automated Message)</em></p>\n</body>\n</html>",
      "encodeParamsToggle": true,
      "formData": {
        "command": "SEND",
        "send": {
          "bodyType": "text/html",
          "from": "uk-pmportal@micross.com",
          "subject": "{{appsmith.store.selectedDepartment+ \" Questions Ready for Sign Off - \" + appsmith.store.selectedPO}}",
          "to": "{{GetDepartmentApproverEmails.data.map(u => u.Email).join(\", \")}}"
        }
      },
      "paginationType": "NONE",
      "timeoutInMillisecond": 10000
    },
    "confirmBeforeExecute": false,
    "datasource": {
      "id": "SMTP-UK-PMPortal",
      "isAutoGenerated": false,
      "name": "SMTP-UK-PMPortal",
      "pluginId": "smtp-plugin"
    },
    "dynamicBindingPathList": [
      {
        "key": "formData.send.to"
      },
      {
        "key": "body"
      },
      {
        "key": "formData.send.subject"
      }
    ],
    "name": "SendApproverEmail",
    "pageId": "Home",
    "runBehaviour": "MANUAL",
    "userSetOnLoad": false
  }
}