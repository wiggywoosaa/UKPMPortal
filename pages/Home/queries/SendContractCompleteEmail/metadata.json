{
  "gitSyncId": "69ccf8e72446822078bf9d91_c95e7c50-1bc9-4e66-8355-15f5d7897d3a",
  "id": "Home_SendContractCompleteEmail",
  "pluginId": "smtp-plugin",
  "pluginType": "DB",
  "unpublishedAction": {
    "actionConfiguration": {
      "body": "<html>\n<body style=\"font-family: Arial, sans-serif; font-size: 14px; color: #333;\">\n  <p>Hello,</p>\n  <p>The following Contract Review has been fully approved:</p>\n  <ul>\n    <li><strong>Contract Review:</strong> {{ appsmith.store.selectedPO_Questions }}</li>\n    <li><strong>Customer:</strong> {{ appsmith.store.fullPO.header.CustomerDivision }}</li>\n    <li><strong>PO Number:</strong> {{ appsmith.store.fullPO.header.CustomerPurchaseOrderNumber }}</li>\n  </ul>\n  <p>Please acknowledge the order in accordance with Q145.</p>\n  <p>This email confirms the Contract Review is officially complete.</p>\n  <br/>\n  <p>Thank you.</p>\n  <p><em>PM Portal (Automated Message)</em></p>\n</body>\n</html>",
      "encodeParamsToggle": true,
      "formData": {
        "command": "SEND",
        "send": {
          "bodyType": "text/html",
          "from": "uk-pmportal@micross.com",
          "subject": "{{\"Contract Review Complete - Order Ready for Acknowledgement - \" + appsmith.store.selectedPO_Questions}}",
          "to": "{{GetInternalSalesEmails.data.map(u => u.Email).join(\", \")}}"
        }
      },
      "paginationType": "NONE",
      "timeoutInMillisecond": 10000
    },
    "confirmBeforeExecute": false,
    "datasource": {
      "id": "SMTP-UK-PMPortal",
      "isAutoGenerated": false,
      "name": "SMTP-UK-PMPortal",
      "pluginId": "smtp-plugin"
    },
    "dynamicBindingPathList": [
      {
        "key": "formData.send.to"
      },
      {
        "key": "formData.send.subject"
      },
      {
        "key": "body"
      }
    ],
    "name": "SendContractCompleteEmail",
    "pageId": "Home",
    "runBehaviour": "MANUAL",
    "userSetOnLoad": false
  }
}