{
  "gitSyncId": "69ccf8e72446822078bf9d91_bc2e9017-a7ae-4c43-ac85-a616a1e003eb",
  "id": "Home_SendPMVerificationEmail",
  "pluginId": "smtp-plugin",
  "pluginType": "DB",
  "unpublishedAction": {
    "actionConfiguration": {
      "body": "<html>\n<body style=\"font-family: Arial, sans-serif; font-size: 14px; color: #333;\">\n  <p>Hello,</p>\n  <p>All departmental reviews are complete for the following Contract Review:</p>\n  <ul>\n    <li><strong>Contract Review:</strong> {{ appsmith.store.selectedPO_Questions }}</li>\n    <li><strong>Customer:</strong> {{ appsmith.store.fullPO.header.CustomerDivision }}</li>\n  </ul>\n  <p>Please perform PM Verification and complete the risk matrix.</p>\n  <br/>\n  <p>Thank you.</p>\n  <p><em>PM Portal (Automated Message)</em></p>\n</body>\n</html>",
      "encodeParamsToggle": true,
      "formData": {
        "command": "SEND",
        "send": {
          "bodyType": "text/html",
          "from": "uk-pmportal@micross.com",
          "subject": "{{\"Program Manager Verification Required - \" + appsmith.store.selectedPO_Questions}}",
          "to": "{{GetPMVerificationEmails.data.map(u => u.Email).join(\", \")}}"
        }
      },
      "paginationType": "NONE",
      "timeoutInMillisecond": 10000
    },
    "confirmBeforeExecute": false,
    "datasource": {
      "id": "SMTP-UK-PMPortal",
      "isAutoGenerated": false,
      "name": "SMTP-UK-PMPortal",
      "pluginId": "smtp-plugin"
    },
    "dynamicBindingPathList": [
      {
        "key": "formData.send.to"
      },
      {
        "key": "formData.send.subject"
      },
      {
        "key": "body"
      }
    ],
    "executeOnLoad": false,
    "name": "SendPMVerificationEmail",
    "pageId": "Home",
    "userSetOnLoad": false
  }
}