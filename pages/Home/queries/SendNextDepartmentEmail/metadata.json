{
  "gitSyncId": "69ccf8e72446822078bf9d91_d5e933c3-11bc-4eaa-9294-7a81bc9cfa5e",
  "id": "Home_SendNextDepartmentEmail",
  "pluginId": "smtp-plugin",
  "pluginType": "DB",
  "unpublishedAction": {
    "actionConfiguration": {
      "body": "<html>\n<body style=\"font-family: Arial, sans-serif; font-size: 14px; color: #333;\">\n  <p>Hello,</p>\n  <p>A Contract Review is ready for your department to review.</p>\n  <ul>\n    <li><strong>Contract Review:</strong> {{ appsmith.store.selectedPO_Questions }}</li>\n    <li><strong>Customer:</strong> {{ appsmith.store.fullPO.header.CustomerDivision }}</li>\n    <li><strong>Stage:</strong> {{ GetNextDepartmentForPO.data[0].Department }} Review</li>\n  </ul>\n  <p>Please complete all questions assigned to your department in the PM Portal.</p>\n  <br/>\n  <p>Thank you.</p>\n  <p><em>PM Portal (Automated Message)</em></p>\n</body>\n</html>",
      "encodeParamsToggle": true,
      "formData": {
        "command": "SEND",
        "send": {
          "bodyType": "text/html",
          "from": "uk-pmportal@micross.com",
          "subject": "{{\"Contract Review Awaiting Your Input - \" + appsmith.store.selectedPO_Questions}}",
          "to": "{{GetNextDepartmentEmails.data.map(u => u.Email).join(\", \")}}"
        }
      },
      "paginationType": "NONE",
      "timeoutInMillisecond": 10000
    },
    "confirmBeforeExecute": false,
    "datasource": {
      "id": "SMTP-UK-PMPortal",
      "isAutoGenerated": false,
      "name": "SMTP-UK-PMPortal",
      "pluginId": "smtp-plugin"
    },
    "dynamicBindingPathList": [
      {
        "key": "formData.send.to"
      },
      {
        "key": "formData.send.subject"
      },
      {
        "key": "body"
      }
    ],
    "name": "SendNextDepartmentEmail",
    "pageId": "Home",
    "runBehaviour": "MANUAL",
    "userSetOnLoad": false
  }
}