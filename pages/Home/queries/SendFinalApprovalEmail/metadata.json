{
  "gitSyncId": "69ccf8e72446822078bf9d91_3f764b0d-ab40-4c61-8b6f-9a5956ba4f64",
  "id": "Home_SendFinalApprovalEmail",
  "pluginId": "smtp-plugin",
  "pluginType": "DB",
  "unpublishedAction": {
    "actionConfiguration": {
      "body": "<html>\n<body style=\"font-family: Arial, sans-serif; font-size: 14px; color: #333;\">\n  <p>Hello,</p>\n  <p>The following Contract Review requires final approval:</p>\n  <ul>\n    <li><strong>Contract Review:</strong> {{ appsmith.store.selectedPO_Questions }}</li>\n    <li><strong>Customer:</strong> {{ appsmith.store.fullPO.header.CustomerDivision }}</li>\n    <li><strong>Order Value:</strong> £{{ appsmith.store.fullPO.header.TotalOrderValue }}</li>\n  </ul>\n  <p>Please log into the PM Portal to approve the review.</p>\n  <br/>\n  <p>Thank you.</p>\n  <p><em>PM Portal (Automated Message)</em></p>\n</body>\n</html>",
      "encodeParamsToggle": true,
      "formData": {
        "command": "SEND",
        "send": {
          "bodyType": "text/html",
          "from": "uk-pmportal@micross.com",
          "subject": "{{\"Final Approval Needed - Contract Review \" + appsmith.store.selectedPO_Questions}}",
          "to": "{{GetFinalApproverEmails.data.map(u => u.Email).join(\", \")}}"
        }
      },
      "paginationType": "NONE",
      "timeoutInMillisecond": 10000
    },
    "confirmBeforeExecute": false,
    "datasource": {
      "id": "SMTP-UK-PMPortal",
      "isAutoGenerated": false,
      "name": "SMTP-UK-PMPortal",
      "pluginId": "smtp-plugin"
    },
    "dynamicBindingPathList": [
      {
        "key": "formData.send.to"
      },
      {
        "key": "formData.send.subject"
      },
      {
        "key": "body"
      }
    ],
    "name": "SendFinalApprovalEmail",
    "pageId": "Home",
    "runBehaviour": "MANUAL",
    "userSetOnLoad": false
  }
}