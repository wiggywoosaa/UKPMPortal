{
  "gitSyncId": "69ccf8e72446822078bf9d91_95b3a6be-2123-4222-803f-3cd733ccb5e4",
  "id": "Home_SendInternalSalesEmail",
  "pluginId": "smtp-plugin",
  "pluginType": "DB",
  "unpublishedAction": {
    "actionConfiguration": {
      "body": "<html>\n<body style=\"font-family: Arial, sans-serif; font-size: 14px; color: #333;\">\n  <p>Hello,</p>\n  <p>A new Contract Review has been opened in the PM Portal.</p>\n  <ul>\n    <li><strong>Customer:</strong> {{ appsmith.store.fullPO.header.CustomerDivision }}</li>\n    <li><strong>PO Number:</strong> {{ appsmith.store.fullPO.header.CustomerPurchaseOrderNumber }}</li>\n    <li><strong>Sales Order:</strong> {{ appsmith.store.fullPO.header.MicrossSalesOrderReference }}</li>\n  </ul>\n  <p>You have been assigned the first stage of the review.</p>\n  <p>Please log into the PM Portal to complete your section.</p>\n  <br/>\n  <p>Thank you.</p>\n  <p><em>PM Portal (Automated Message)</em></p>\n</body>\n</html>",
      "encodeParamsToggle": true,
      "formData": {
        "command": "SEND",
        "send": {
          "bodyType": "text/html",
          "from": "uk-pmportal@micross.com",
          "subject": "{{\"New Contract Review Opened - \" + appsmith.store.fullPO.header.MicrossSalesOrderReference}}",
          "to": "{{GetInternalSalesEmails.data.map(u => u.Email).join(\", \")}}"
        }
      },
      "paginationType": "NONE",
      "timeoutInMillisecond": 10000
    },
    "confirmBeforeExecute": false,
    "datasource": {
      "id": "SMTP-UK-PMPortal",
      "isAutoGenerated": false,
      "name": "SMTP-UK-PMPortal",
      "pluginId": "smtp-plugin"
    },
    "dynamicBindingPathList": [
      {
        "key": "formData.send.to"
      },
      {
        "key": "formData.send.subject"
      },
      {
        "key": "body"
      }
    ],
    "name": "SendInternalSalesEmail",
    "pageId": "Home",
    "runBehaviour": "MANUAL",
    "userSetOnLoad": false
  }
}