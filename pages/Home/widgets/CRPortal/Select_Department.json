  "sourceData": "{{\n(() => {\n\n  const allDepts = GetDepartments.data || [];\n  const entity = GetPOH.data?.[0]?.MicrossEntity;\n  const ctx = appsmith.store.userContext;\n\n  // 🟡 WAIT FOR DATA\n  if (!allDepts.length || !entity || typeof ctx === \"undefined\") {\n    return [];\n  }\n\n  // 🔴 NOT LOGGED IN (extra safety)\n  if (!ctx?.departments) return [];\n\n  const userDeps = ctx.departments\n    .map(d => d?.trim().toLowerCase())\n    .filter(Boolean);\n\n  return allDepts\n    .filter(d => d.MicrossEntity === entity)\n    .filter(d => {\n      const dept = d.Department?.trim().toLowerCase();\n      return userDeps.includes(dept);\n    })\n    .map(d => ({\n      label: d.Department,\n      value: d.Department\n    }));\n\n})()\n}}",
