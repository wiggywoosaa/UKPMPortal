  "listData": "{{\n(() => {\n  const selectedDeptFA = appsmith.store.selectedDepartmentFA;\n  const entity = GetPOHFA.data?.[0]?.MicrossEntity;\n\n  if (!selectedDeptFA || !entity) return [];\n\n  const selectedNorm = selectedDeptFA.trim().toLowerCase();\n\n  return (QuestionBuilder_FA.getQuestionsFA() || []).filter(q => {  // ✅ was getQuestions()\n    const qDept = q.Department?.trim().toLowerCase();\n\n    if (qDept !== selectedNorm) return false;\n\n    if (!q.DependsOnQuestionId) return true;\n    const answer =\n      appsmith.store.answers?.[q.DependsOnQuestionId]?.YesNo\n      ?? q.YesNo;\n    return Number(answer) === Number(q.DependsOnValue);\n  });\n})()\n}}",
