  "listData": "{{\n(() => {\n\n  const selectedDept = appsmith.store.selectedDepartment;\n  const entity = GetPOH.data?.[0]?.MicrossEntity;\n  const ctx = appsmith.store.userContext;\n\n  // 🚨 REQUIRED DATA\n  if (!selectedDept || !entity || !ctx) return [];\n\n  const userDeps = (ctx.departments || [])\n    .map(d => d?.trim().toLowerCase())\n    .filter(Boolean);\n\n  const selectedNorm = selectedDept.trim().toLowerCase();\n\n  return (QuestionBuilder.getQuestions() || []).filter(q => {\n\n    const qDept = q.Department?.trim().toLowerCase();\n\n    // 🔒 PERMISSION CHECK (NO ADMIN BYPASS NOW)\n    if (!userDeps.includes(qDept)) return false;\n\n    // 🎯 DROPDOWN FILTER\n    if (qDept !== selectedNorm) return false;\n\n    // 🔁 DEPENDENCY LOGIC\n    if (!q.DependsOnQuestionId) return true;\n\n    const answer =\n      appsmith.store.answers?.[q.DependsOnQuestionId]?.YesNo\n      ?? q.YesNo;\n\n    return Number(answer) === Number(q.DependsOnValue);\n\n  });\n\n})()\n}}",
