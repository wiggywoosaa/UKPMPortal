  "tableData": "{{\n(() => {\n\n  const data = GetQuestions.data || [];\n\n  const entity =\n    Table_Entities.selectedRowIndex >= 0\n      ? Table_Entities.selectedRow?.MicrossEntity\n      : null;\n\n  const dept =\n    Table_Departments.selectedRowIndex >= 0\n      ? Table_Departments.selectedRow?.Department\n      : null;\n\n  return data.filter(q => {\n\n    if (dept) return q.Department === dept;\n    if (entity) return q.MicrossEntity === entity;\n\n    return true;\n\n  });\n\n})()\n}}",
