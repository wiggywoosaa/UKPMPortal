  "listData": "{{\n(() => {\n\n  // 🚨 must have department selected\n  if (!appsmith.store.selectedDepartment) return [];\n\n  // 🚨 must have entity loaded\n  if (!GetPOH.data?.[0]?.MicrossEntity) return [];\n\n  // 🚨 must be logged in\n  if (!appsmith.store.user) return [];\n\n  // 🚨 must have permissions loaded\n  if (!appsmith.store.userDepartments) return [];\n\n  return (QuestionBuilder.getQuestions() || []).filter(q => {\n\n    // 🚀 ADMIN OVERRIDE\n    if (!appsmith.store.user.isAdmin) {\n\n      // 🔒 HARD PERMISSION CHECK\n      if (!appsmith.store.userDepartments.includes(q.Department)) return false;\n\n    }\n\n    // 🚀 DEPARTMENT DROPDOWN FILTER\n    if (q.Department !== appsmith.store.selectedDepartment) return false;\n\n    // 🚀 EXISTING DEPENDENCY LOGIC (UNCHANGED)\n    if (!q.DependsOnQuestionId) return true;\n\n    const answer =\n      appsmith.store.answers?.[q.DependsOnQuestionId]?.YesNo\n      ?? q.YesNo;\n\n    return Number(answer) === Number(q.DependsOnValue);\n\n  });\n\n})()\n}}",
